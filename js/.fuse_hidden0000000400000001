import gsap from 'gsap';
import ScrollTrigger from 'gsap/ScrollTrigger';

import { initCursor } from './core/cursor.js';
import { initChapterMarker } from './core/ui.js';
import { SceneRegistry } from './core/scenes.js';
import { GlobalRiver } from './core/river.js';

import { HeroChapter } from './chapters/chapter-01-hero.js';
import { AboutChapter } from './chapters/chapter-02-about.js';
import { AttentionChapter } from './chapters/chapter-03-attention.js';
import { ResearchChapter } from './chapters/chapter-04-research.js';
import { TrialChapter } from './chapters/chapter-05-trial.js';
import { ToneSpeechChapter } from './chapters/chapter-06-tone-speech.js';
import { ContactChapter } from './chapters/chapter-07-contact.js';

gsap.registerPlugin(ScrollTrigger);

const CHAPTERS = [
  { id: '01', cls: HeroChapter,       hasCanvas: false, eager: true  },
  { id: '02', cls: AboutChapter,      hasCanvas: false, eager: true  },
  { id: '03', cls: AttentionChapter,  hasCanvas: true,  eager: false },
  { id: '04', cls: ResearchChapter,   hasCanvas: true,  eager: false },
  { id: '05', cls: TrialChapter,      hasCanvas: true,  eager: false },
  { id: '06', cls: ToneSpeechChapter, hasCanvas: true,  eager: false },
  { id: '07', cls: ContactChapter,    hasCanvas: false, eager: false },
];

/* tiny try/catch wrapper so one subsystem failure doesn't abort boot */
function safe(label, fn) {
  try { return fn(); }
  catch (e) { console.error(`[${label}]`, e); return null; }
}

function boot() {
  console.log('%c GUHAN VENKAT — booting… ', 'background:#0c0c0c;color:#c8f542;padding:6px 10px;font-family:monospace;letter-spacing:.15em;');

  const updateCursor = safe('cursor', () => initCursor()) || (() => {});
  safe('hud', () => initChapterMarker());

  /* River — render-loop renderer; if WebGL fails we still want chapters to work */
  const riverCanvas = document.getElementById('river-canvas');
  let river = null;
  safe('river-init', () => {
    river = new GlobalRiver(riverCanvas);
    river.init();
    window.__river = river;
  });

  /* Registry */
  const registry = new SceneRegistry();
  for (const c of CHAPTERS) {
    const section = document.getElementById(`ch-${c.id}`);
    if (!section) continue;
    const canvas = c.hasCanvas
      ? document.querySelector(`.chapter-canvas-wrap[data-canvas="${c.id}"] canvas.chapter-canvas`)
      : null;
    registry.register({
      id: c.id,
      section,
      canvas,
      eager: c.eager,
      factory: (cv, s) => new c.cls(cv, s),
    });
  }
  registry.start();

  /* Eager init for chapters that should set up immediately (hero/about) so
     their reveals don't depend on a ScrollTrigger toggling onLoad. */
  for (const entry of registry.entries) {
    if (entry.eager && !entry.chapter) {
      safe(`chapter-${entry.id}-init`, () => {
        entry.chapter = entry.factory(entry.canvas, entry.section);
        entry.chapter.init();
        entry.chapter.isActive = true;
      });
    }
  }

  /* ScrollTrigger activation. Each chapter wrapper crossfades; canvas-bearing
     chapters lazy-init on first entry. */
  for (const entry of registry.entries) {
    const wrap = entry.canvas
      ? document.querySelector(`.chapter-canvas-wrap[data-canvas="${entry.id}"]`)
      : null;
    const fadeTween = wrap
      ? gsap.to(wrap, { opacity: 1, duration: 0.45, ease: 'power2.out', paused: true })
      : null;

    ScrollTrigger.create({
      trigger: entry.section,
      start: 'top 80%',
      end: 'bottom 20%',
      toggleActions: 'play reverse play reverse',
      animation: fadeTween || undefined,
      onToggle: (self) => {
        if (self.isActive && !entry.chapter) {
          safe(`chapter-${entry.id}-init`, () => {
            entry.chapter = entry.factory(entry.canvas, entry.section);
            entry.chapter.init();
            if (entry.canvas) entry.chapter.resize(window.innerWidth, window.innerHeight);
          });
        }
        if (entry.chapter) entry.chapter.isActive = self.isActive;
        if (wrap) wrap.classList.toggle('is-active', self.isActive);
      },
    });
  }

  ScrollTrigger.refresh();

  /* Global rAF */
  let last = performance.now();
  function frame(now) {
    const delta = Math.min((now - last) / 1000, 1 / 20);
    last = now;
    updateCursor();
    if (river) river.tick(now / 1000, delta);
    registry.tick(now / 1000, delta);
    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);

  /* Scroll → river forward flow */
  let lastScrollY = window.scrollY;
  window.addEventListener('scroll', () => {
    const cur = window.scrollY;
    const ds = cur - lastScrollY;
    lastScrollY = cur;
    if (river) river.onScroll(cur, ds);
  }, { passive: true });

  /* Mouse → river repulsion */
  window.addEventListener('mousemove', (e) => {
    if (river) river.onMouseMove(e.clientX, e.clientY);
  }, { passive: true });

  /* Debounced resize */
  let resizeTimer = null;
  window.addEventListener('resize', () => {
    if (resizeTimer) clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      registry.resize(window.innerWidth, window.innerHeight);
      if (river) river.resize(window.innerWidth, window.innerHeight);
      ScrollTrigger.refresh();
    }, 150);
  });

  console.log('%c GUHAN VENKAT — booted. ', 'background:#c8f542;color:#0c0c0c;padding:6px 10px;font-family:monospace;letter-spacing:.15em;');
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', boot);
} else {
  boot();
}
