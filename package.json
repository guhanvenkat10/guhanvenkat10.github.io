{
  "name": "guhan-venkat-portfolio",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Personal site of Guhan Venkat \u2014 static, no build required to view.",
  "scripts": {
    "serve": "npx -y serve .",
    "dev": "vite",
    "bundle": "esbuild js/app.js --bundle --format=iife --target=es2019 --outfile=js/app.bundle.js",
    "build": "esbuild js/app.js --bundle --format=iife --target=es2019 --minify --outfile=js/app.bundle.js"
  },
  "dependencies": {
    "three": "0.160.0",
    "gsap": "3.12.5"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "vite": "^5.4.10"
  }
}